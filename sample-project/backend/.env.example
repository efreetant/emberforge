# Backend environment — copy to .env and fill in values.
# These are PROJECT-SPECIFIC settings. Harness API keys (AGENT_PROVIDER etc.)
# belong in the root .env of the agent-harness repo, not here.

# ============================================================
# Database
# ============================================================
DATABASE_URL=sqlite:///./app.db

# ============================================================
# Auth / JWT
# ============================================================
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================
# CORS (comma-separated origins the frontend is served from)
# ============================================================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# External APIs used by the application (add as needed)
# ============================================================
# OPENAI_API_KEY=sk-your-app-llm-key-here
# STRIPE_SECRET_KEY=sk_test_your-stripe-key
